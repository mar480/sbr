{
  "name": "sbr-revision-quiz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev:phone": "concurrently \"npm:dev:server\" \"vite --host 0.0.0.0\"",
    "build": "vite build",
    "start": "node server/start.js",
    "test": "vitest run",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "supertest": "^7.0.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
